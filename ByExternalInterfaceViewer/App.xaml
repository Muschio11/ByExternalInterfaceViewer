<Application x:Class="ByExternalInterfaceViewer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ByExternalInterfaceViewer"
             xmlns:vm="clr-namespace:ByExternalInterfaceViewer.ViewModels"
             xmlns:views="clr-namespace:ByExternalInterfaceViewer.Views">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Button.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type vm:CassetteContentsViewModel}">
                <views:CassetteContentsView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:MovementsListViewModel}">
                <views:MovementsListView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:FilterMovementsViewModel}">
                <views:FilterMovementsView/>
            </DataTemplate>


        </ResourceDictionary>

        
    </Application.Resources>
</Application>
