<Window x:Class="ByExternalInterfaceViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ByExternalInterfaceViewer"
        xmlns:vm="clr-namespace:ByExternalInterfaceViewer.ViewModels"
        xmlns:views="clr-namespace:ByExternalInterfaceViewer.Views"
        mc:Ignorable="d"
        Title="ByExternal Interface Viewer" Height="1050" Width="1680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        MouseDown="Window_MouseDown">
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>





        <Menu VerticalAlignment="Top" Background="#FF333333" Foreground="White">
            <MenuItem Header="_File">
                <MenuItem Header="_Exit" Command="{Binding ExitCommand}" Foreground="Black"/>
            </MenuItem>
            <!--<MenuItem Header="Options">
                <MenuItem Header="_Refresh" Command="{Binding SettingsCommand}"/>
            </MenuItem>-->
        </Menu>

        <StackPanel Grid.Row="1" Background="#FF211B1B">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <RadioButton Grid.Column="0" Style="{StaticResource MenuRadioButtonStyle}" Content="Elenco Movimentazioni" IsChecked="True" Command="{Binding ShowMovementsListCommand}"/>
                <RadioButton Grid.Column="1" Style="{StaticResource MenuRadioButtonStyle}" Content="Elenco Contenuto Cassetti"  Command="{Binding ShowCassetteContentListCommand}"/>

            </Grid>
        </StackPanel>
        <Grid Grid.Row="2" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>
            <Grid  Background="#FF211B1B">
                <ContentControl  Content="{Binding CurrentViewModel}"
                                 Margin="10"/>
                
            </Grid>
            <Border Grid.Column="1" Background="#FF211B1B" BorderBrush="Red" BorderThickness="2" Height="965" Width="300" VerticalAlignment="Top">
                <ContentControl  Content="{Binding FilterViewModel}"/>
            </Border>
         
        </Grid>

        

    </Grid>
</Window>
